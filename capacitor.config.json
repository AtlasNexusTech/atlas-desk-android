{
  "appId": "tech.atlasnexus.atlasdesk",
  "appName": "Atlas Desk",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
